# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Deepgram Speech-to-Text ───────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_prd_generator

# ── Slack ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Optional: public Slack invite link shown on the launch form
# SLACK_INVITE_URL=https://join.slack.com/t/your-workspace/shared_invite/...
# Optional: Slack slash-command verification token for /api/slack/prd
# SLACK_SLASH_COMMAND_TOKEN=your_slack_command_token
# Recommended: Slack signing secret for slash commands and interactive approvals
# SLACK_SIGNING_SECRET=your_slack_signing_secret

# ── Linear ────────────────────────────────────────────────
# Required for Slack "Approve Linear Tickets"
# LINEAR_API_KEY=lin_api_your_key_here
# LINEAR_TEAM_ID=your_linear_team_uuid
# Optional targeting for created issues
# LINEAR_PROJECT_ID=your_linear_project_uuid
# LINEAR_ASSIGNEE_ID=your_linear_user_uuid
# LINEAR_LABEL_IDS=label_uuid_one,label_uuid_two

# ── Bot Settings ──────────────────────────────────────────
BOT_DISPLAY_NAME=AI Notetaker
PORT=3000
# Set true in hosted production. Keep false locally if you want to watch the bot browser.
PLAYWRIGHT_HEADLESS=false

# ── Auth (auto-generated by `npm run auth-setup`) ────────
# AUTH_STATE_PATH=./auth-state.json
