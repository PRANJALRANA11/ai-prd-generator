# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Deepgram Speech-to-Text ───────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_prd_generator

# ── Slack ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Optional: Slack slash-command verification token for /api/slack/prd
# SLACK_SLASH_COMMAND_TOKEN=your_slack_command_token

# ── Bot Settings ──────────────────────────────────────────
BOT_DISPLAY_NAME=AI Notetaker
PORT=3000

# ── Auth (auto-generated by `npm run auth-setup`) ────────
# AUTH_STATE_PATH=./auth-state.json
# Optional for hosted deployments: base64 contents of auth-state.json
# AUTH_STATE_JSON_BASE64=
