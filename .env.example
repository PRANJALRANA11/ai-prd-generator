# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Deepgram Speech-to-Text ───────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_prd_generator

# ── Slack ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Public URL used in Slack buttons, Live Codex links, and Slack callbacks.
# PUBLIC_BASE_URL=https://ai-prd-generator-fshh.onrender.com
# Optional: public Slack invite link shown on the launch form
# SLACK_INVITE_URL=https://join.slack.com/t/your-workspace/shared_invite/...
# Optional: Slack slash-command verification token for /api/slack/prd
# SLACK_SLASH_COMMAND_TOKEN=your_slack_command_token
# Recommended: Slack signing secret for slash commands and interactive approvals
# SLACK_SIGNING_SECRET=your_slack_signing_secret
# Optional: bot token with app_mentions:read and chat:write for @bot status replies
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ── Linear ────────────────────────────────────────────────
# Optional: public Linear invite or workspace link shown on the launch form
# LINEAR_INVITE_URL=https://linear.app/your-workspace
# Required for Slack "Approve Linear Tickets"
# LINEAR_API_KEY=lin_api_your_key_here
# LINEAR_TEAM_ID=your_linear_team_uuid
# Optional targeting for created issues
# LINEAR_PROJECT_ID=your_linear_project_uuid
# LINEAR_ASSIGNEE_ID=your_linear_user_uuid
# LINEAR_LABEL_IDS=label_uuid_one,label_uuid_two
# Optional explicit completed state. If omitted, the app tries to find a Done/Completed state on LINEAR_TEAM_ID.
# LINEAR_DONE_STATE_ID=your_linear_done_state_uuid

# ── GitHub + Codex Coding Agent ───────────────────────────
# Required to mirror Linear tickets to GitHub issues and PRs
# GITHUB_TOKEN=ghp_or_fine_grained_token
# GITHUB_REPO=owner/repo
# Optional for git clone/push auth. Defaults to the repo owner.
# GITHUB_USERNAME=your_github_username
# Required by Codex CLI in hosted/non-interactive Render runs
# OPENAI_API_KEY=sk-...
# Optional explicit Codex CLI auth. If omitted, the app passes OPENAI_API_KEY through as CODEX_API_KEY.
# CODEX_API_KEY=sk-...
# Optional labels created/applied to mirrored GitHub issues
# GITHUB_ISSUE_LABELS=prd-generated,codex-agent
# Optional git commit identity for Codex-authored commits
# CODING_AGENT_GIT_NAME=SDLC0 Codex Agent
# CODING_AGENT_GIT_EMAIL=codex-agent@users.noreply.github.com
# Enable the background Codex worker
# CODING_AGENT_ENABLED=false
# Branch Codex should branch from
# CODING_AGENT_BASE_BRANCH=master
# Local temp clone directory used by the worker
# CODING_AGENT_WORKDIR=/tmp/ai-prd-coding-agent
# Codex CLI command template. {promptFile} and {branch} are replaced automatically.
# CODING_AGENT_COMMAND=codex exec --model gpt-4o-mini --sandbox workspace-write --skip-git-repo-check {prompt}

# ── Bot Settings ──────────────────────────────────────────
BOT_DISPLAY_NAME=AI Notetaker
PORT=3000
# Set true in hosted production. Keep false locally if you want to watch the bot browser.
PLAYWRIGHT_HEADLESS=false

# ── Auth (auto-generated by `npm run auth-setup`) ────────
# AUTH_STATE_PATH=./auth-state.json
